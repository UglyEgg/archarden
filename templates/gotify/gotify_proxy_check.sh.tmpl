#!/usr/bin/env bash
set -euo pipefail

env_file="/etc/archarden/notify-gotify.env"
if [[ -f "${env_file}" ]]; then
  # shellcheck disable=SC1090
  source "${env_file}"
fi

external_url="${GOTIFY_EXTERNAL_URL:-}"
if [[ -z "${external_url}" ]]; then
  exit 0
fi

# If the proxy path is down, attempt to notify via the internal Gotify API URL.
# This avoids a deadlock where a broken proxy prevents the alert from being delivered.
if ! curl -fsS -k --max-time 6 --connect-timeout 3 "${external_url%/}/health" >/dev/null 2>&1; then
  if [[ -x /usr/lib/archarden/gotify_send.sh ]]; then
    /usr/lib/archarden/gotify_send.sh \
      "Gotify proxy unreachable" \
      "Health check failed for ${external_url%/} at $(date -u +%Y-%m-%dT%H:%M:%SZ). NPM/proxy may be misconfigured or down." || true
  fi
fi
